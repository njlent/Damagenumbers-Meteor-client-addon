{
  "schemaVersion": 1,
  "id": "damage-numbers-meteor-addon",
  "version": "${version}",
  "name": "Damage Numbers Meteor Addon",
  "description": "Meteor Client combat module for floating damage numbers.",
  "authors": [
    "luavixen",
    "njlent"
  ],
  "contact": {
    "sources": "https://github.com/njlent/Damagenumbers-Meteor-client-addon"
  },
  "icon": "assets/damagenumbers/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "de.njlent.damagenumbers.DamageNumbersMeteorAddon"
    ]
  },
  "mixins": [
    "damage-numbers-meteor.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "fabricloader": ">=0.19.2",
    "fabric-api": "*",
    "meteor-client": "*"
  }
